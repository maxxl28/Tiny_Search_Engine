#!/bin/bash

# Ale Sprin26

PAGEDIR=../crawler/testdata/letters-10
INDEXFILE=letters-10.index

../indexer/indexer $PAGEDIR $INDEXFILE

# arg stuff
echo "Argument tests"
Argument tests

./querier
Usage: ./querier pageDirectory indexFilename

./querier $PAGEDIR
Usage: ./querier pageDirectory indexFilename

# three arguments
./querier $PAGEDIR $INDEXFILE extra
Usage: ./querier pageDirectory indexFilename

# directory
./querier /no/such/dir $INDEXFILE
Error: invalid pageDirectory: /no/such/dir

./querier /tmp $INDEXFILE
Error: invalid pageDirectory: /tmp

./querier $PAGEDIR /no/such/file
Error: cannot read indexFilename: /no/such/file


# making sure syntaz is checked
echo "Syntax error tests"
Syntax error tests
./querier $PAGEDIR $INDEXFILE <<EOF
and
or
and earth
or earth
planet earth or
planet earth and
planet earth and or science
planet earth and and science
planet earth or and science
Warning!
hello (world)
EOF
Error: 'and' cannot be first
Error: 'or' cannot be first
Error: 'and' cannot be first
Error: 'or' cannot be first
Error: 'or' cannot be last
Error: 'and' cannot be last
Error: 'and' and 'or' cannot be adjacent
Error: 'and' and 'and' cannot be adjacent
Error: 'or' and 'and' cannot be adjacent
Error: invalid character in query
Error: invalid character in query


# correctness
echo "Test: words"
Test: words
./querier $PAGEDIR $INDEXFILE <<EOF
home
tse
for
nonexistentword
EOF
