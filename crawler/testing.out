#!/bin/bash

CRAWLER=./crawler
LETTERS=http://cs50tse.cs.dartmouth.edu/tse/letters/
TOSCRAPE=http://cs50tse.cs.dartmouth.edu/tse/toscrape/
WIKIPEDIA=http://cs50tse.cs.dartmouth.edu/tse/wikipedia/
DATA=./testdata

mkdir -p $DATA

# Error cases

echo "Test: no arguments"
Test: no arguments
$CRAWLER
Usage: ./crawler seedURL pageDirectory maxDepth
echo "Exit: $?"
Exit: 1

echo "Test: too few arguments"
Test: too few arguments
$CRAWLER $LETTERS $DATA/tmp
Usage: ./crawler seedURL pageDirectory maxDepth
echo "Exit: $?"
Exit: 1

echo "Test: too many arguments"
Test: too many arguments
$CRAWLER $LETTERS $DATA/tmp 0 extra
Usage: ./crawler seedURL pageDirectory maxDepth
echo "Exit: $?"
Exit: 1

echo "Test: non-internal seedURL"
Test: non-internal seedURL
$CRAWLER http://www.google.com $DATA/tmp 0
Error: seedURL could not be normalized
echo "Exit: $?"
Exit: 1

echo " Test: invalid seedURL (not a URL)"
 Test: invalid seedURL (not a URL)
$CRAWLER notaURL $DATA/tmp 0
Error: seedURL could not be normalized
echo "Exit: $?"
Exit: 1

echo "Test: non-existent pageDirectory"
Test: non-existent pageDirectory
$CRAWLER $LETTERS $DATA/doesNotExist 0
Error: cannot initialize pageDirectory: ./testdata/doesNotExist
echo "Exit: $?"
Exit: 1

echo "Test: maxDepth negative "
Test: maxDepth negative 
mkdir -p $DATA/tmp
$CRAWLER $LETTERS $DATA/tmp -1
Error: maxDepth must be between 0 and 10
echo "Exit: $?"
Exit: 1

echo "Test: maxDepth too large "
Test: maxDepth too large 
$CRAWLER $LETTERS $DATA/tmp 11
Error: maxDepth must be between 0 and 10
echo "Exit: $?"
Exit: 1

echo "Test: maxDepth not an integer "
Test: maxDepth not an integer 
$CRAWLER $LETTERS $DATA/tmp foo
Error: maxDepth must be an integer
echo "Exit: $?"
Exit: 1

# Valgrind memory check

echo "Test: valgrind on toscrape depth 1"
Test: valgrind on toscrape depth 1
mkdir -p $DATA/valgrind
valgrind --leak-check=full --error-exitcode=1 \
    $CRAWLER $TOSCRAPE $DATA/valgrind 1
==367246== Memcheck, a memory error detector
==367246== Copyright (C) 2002-2024, and GNU GPL'd, by Julian Seward et al.
==367246== Using Valgrind-3.26.0 and LibVEX; rerun with -h for copyright info
==367246== Command: ./crawler http://cs50tse.cs.dartmouth.edu/tse/toscrape/ ./testdata/valgrind 1
==367246== 
==367246== 
==367246== HEAP SUMMARY:
==367246==     in use at exit: 9,123 bytes in 20 blocks
==367246==   total heap usage: 2,356,156 allocs, 2,356,136 frees, 44,068,487,424 bytes allocated
==367246== 
==367246== LEAK SUMMARY:
==367246==    definitely lost: 0 bytes in 0 blocks
==367246==    indirectly lost: 0 bytes in 0 blocks
==367246==      possibly lost: 0 bytes in 0 blocks
==367246==    still reachable: 9,123 bytes in 20 blocks
==367246==         suppressed: 0 bytes in 0 blocks
==367246== Reachable blocks (those to which a pointer was found) are not shown.
==367246== To see them, rerun with: --leak-check=full --show-leak-kinds=all
==367246== 
==367246== For lists of detected and suppressed errors, rerun with: -s
==367246== ERROR SUMMARY: 0 errors from 0 contexts (suppressed: 0 from 0)
echo "Exit: $?"
Exit: 0

# Valid crawls

echo "Test: letters at depth 0"
Test: letters at depth 0
mkdir -p $DATA/letters-0
$CRAWLER $LETTERS $DATA/letters-0 0
echo "Exit: $?"
Exit: 0
ls $DATA/letters-0
1

echo "Test: letters at depth 10"
Test: letters at depth 10
mkdir -p $DATA/letters-10
$CRAWLER $LETTERS $DATA/letters-10 10
echo "Exit: $?"
Exit: 0
ls $DATA/letters-10
1
10
