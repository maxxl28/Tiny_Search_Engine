#!/bin/bash

# Ale Sprin26

CRAWLER_DATA=../crawler/testdata

#args
echo "Test: no arguments"
Test: no arguments
./indexer
Usage: ./indexer pageDirectory indexFilename
echo "Exit: $?"
Exit: 1

echo "Test: one argument"
Test: one argument
./indexer $CRAWLER_DATA/letters-0
Usage: ./indexer pageDirectory indexFilename
echo "Exit: $?"
Exit: 1

echo "Test: extra arguments"
Test: extra arguments
./indexer $CRAWLER_DATA/letters-0 myindex extra
Usage: ./indexer pageDirectory indexFilename
echo "Exit: $?"
Exit: 1

# pageDirectories stuff
echo "Test: bad pageDirectory"
Test: bad pageDirectory
./indexer /nonexistent/path myindex
Error: '/nonexistent/path' is not a valid crawler directory
echo "Exit: $?"
Exit: 1

echo "Test: not crawler dir"
Test: not crawler dir
./indexer /tmp myindex
Error: '/tmp' is not a valid crawler directory
echo "Exit: $?"
Exit: 1

echo "Test: bad indexFile path"
Test: bad indexFile path
./indexer $CRAWLER_DATA/letters-0 /nonexistent/dir/myindex
Error: cannot open '/nonexistent/dir/myindex' for writing
echo "Exit: $?"
Exit: 1

echo "Test: read-only directory"
Test: read-only directory
mkdir -p readonlydir
chmod -w readonlydir
./indexer $CRAWLER_DATA/letters-0 readonlydir/myindex
Error: cannot open 'readonlydir/myindex' for writing
echo "Exit: $?"
Exit: 1
chmod +w readonlydir
rm -rf readonlydir

echo "Test: read-only file"
Test: read-only file
touch readonlyfile
chmod -w readonlyfile
./indexer $CRAWLER_DATA/letters-0 readonlyfile
Error: cannot open 'readonlyfile' for writing
echo "Exit: $?"
Exit: 1
chmod +w readonlyfile
rm -f readonlyfile

# letters depth and test with indextest
echo "Test: letters depth 0"
Test: letters depth 0
./indexer $CRAWLER_DATA/letters-0 myindex_letters0
echo "Exit: $?"
Exit: 0
./indextest myindex_letters0 myindex_letters0_copy
echo "Exit: $?"
Exit: 0

echo "Test: letters depth 10"
Test: letters depth 10
./indexer $CRAWLER_DATA/letters-10 myindex_letters10
echo "Exit: $?"
Exit: 0
./indextest myindex_letters10 myindex_letters10_copy
echo "Exit: $?"
Exit: 0

echo "Test: toscrape depth 1"
Test: toscrape depth 1
./indexer $CRAWLER_DATA/toscrape-1 myindex_toscrape1
echo "Exit: $?"
Exit: 0
./indextest myindex_toscrape1 myindex_toscrape1_copy
echo "Exit: $?"
Exit: 0

echo "Test: wikipedia depth 1"
Test: wikipedia depth 1
./indexer $CRAWLER_DATA/wikipedia-1 myindex_wikipedia1
echo "Exit: $?"
Exit: 0
./indextest myindex_wikipedia1 myindex_wikipedia1_copy
echo "Exit: $?"
Exit: 0

# valgrind 
echo "Test: valgrind indexer"
Test: valgrind indexer
valgrind --leak-check=full --show-leak-kinds=all ./indexer $CRAWLER_DATA/letters-10 myindex_valgrind 2>&1
==735352== Memcheck, a memory error detector
==735352== Copyright (C) 2002-2024, and GNU GPL'd, by Julian Seward et al.
==735352== Using Valgrind-3.26.0 and LibVEX; rerun with -h for copyright info
==735352== Command: ./indexer ../crawler/testdata/letters-10 myindex_valgrind
==735352== 
==735352== 
==735352== HEAP SUMMARY:
==735352==     in use at exit: 0 bytes in 0 blocks
==735352==   total heap usage: 1,564 allocs, 1,564 frees, 134,677 bytes allocated
==735352== 
==735352== All heap blocks were freed -- no leaks are possible
==735352== 
==735352== For lists of detected and suppressed errors, rerun with: -s
==735352== ERROR SUMMARY: 0 errors from 0 contexts (suppressed: 0 from 0)
echo "Exit: $?"
Exit: 0

echo "Test: valgrind indextest"
Test: valgrind indextest
valgrind --leak-check=full --show-leak-kinds=all ./indextest myindex_letters10 myindex_valgrind_copy 2>&1
==735354== Memcheck, a memory error detector
==735354== Copyright (C) 2002-2024, and GNU GPL'd, by Julian Seward et al.
==735354== Using Valgrind-3.26.0 and LibVEX; rerun with -h for copyright info
==735354== Command: ./indextest myindex_letters10 myindex_valgrind_copy
==735354== 
==735354== 
==735354== HEAP SUMMARY:
==735354==     in use at exit: 0 bytes in 0 blocks
==735354==   total heap usage: 172 allocs, 172 frees, 13,612 bytes allocated
==735354== 
==735354== All heap blocks were freed -- no leaks are possible
==735354== 
==735354== For lists of detected and suppressed errors, rerun with: -s
==735354== ERROR SUMMARY: 0 errors from 0 contexts (suppressed: 0 from 0)
echo "Exit: $?"
Exit: 0

# cleanup
rm -f myindex_*
