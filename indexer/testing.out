==370671== 
==370671== 
==370671== HEAP SUMMARY:
==370671==     in use at exit: 0 bytes in 0 blocks
==370671==   total heap usage: 1,564 allocs, 1,564 frees, 134,677 bytes allocated
==370671== 
==370671== All heap blocks were freed -- no leaks are possible
==370671== 
==370671== For lists of detected and suppressed errors, rerun with: -s
==370671== ERROR SUMMARY: 0 errors from 0 contexts (suppressed: 0 from 0)
echo "Exit: $?"
Exit: 0

echo "=== Test 12: Valgrind on indextest ==="
=== Test 12: Valgrind on indextest ===
valgrind --leak-check=full ./indextest myindex_letters10 myindex_valgrind_copy 2>&1
==370673== Memcheck, a memory error detector
==370673== Copyright (C) 2002-2024, and GNU GPL'd, by Julian Seward et al.
==370673== Using Valgrind-3.26.0 and LibVEX; rerun with -h for copyright info
==370673== Command: ./indextest myindex_letters10 myindex_valgrind_copy
==370673== 
==370673== 
==370673== HEAP SUMMARY:
==370673==     in use at exit: 0 bytes in 0 blocks
==370673==   total heap usage: 172 allocs, 172 frees, 13,612 bytes allocated
==370673== 
==370673== All heap blocks were freed -- no leaks are possible
==370673== 
==370673== For lists of detected and suppressed errors, rerun with: -s
==370673== ERROR SUMMARY: 0 errors from 0 contexts (suppressed: 0 from 0)
echo "Exit: $?"
Exit: 0

# Cleanup
rm -f myindex_*
